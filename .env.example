# ============================================================
# billings-mob — variáveis de ambiente (template)
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite .env.local ou qualquer arquivo com valores reais.
# ============================================================

# Supabase — obtenha em https://app.supabase.com/project/gcwxwrjzbbqkuzcweyut/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry — Frontend (React/PWA)
# Obtenha em https://sentry.io → seu projeto → Settings → Client Keys (DSN)
# Adicione também em: Vercel Dashboard > billings-mob > Settings > Environment Variables
VITE_SENTRY_DSN=

# Sentry — API (Hono.js serverless)
# Use o mesmo DSN ou um projeto Sentry separado para o backend
# Adicione em: Vercel Dashboard > billings-mob > Settings > Environment Variables
SENTRY_DSN=

# Sentry — Source Maps Upload (apenas CI/build de produção)
# Obtenha em https://sentry.io → Settings → Auth Tokens
# Adicione em: GitHub Secrets (Settings > Secrets and variables > Actions > SENTRY_AUTH_TOKEN)
# e em Vercel Dashboard > billings-mob > Settings > Environment Variables
SENTRY_AUTH_TOKEN=

# Sentry — Organização e Projeto (para o vite plugin de source maps)
SENTRY_ORG=
SENTRY_PROJECT=billings-mob

# URL de redirecionamento após magic link (produção)
VITE_AUTH_REDIRECT_URL=https://billings-mob.vercel.app

# Upstash Redis — rate limiting global (ADR-017)
# Obtenha em https://console.upstash.com → seu banco Redis → REST API
# Quando configurado, substitui o rate limiter in-memory por um global (todos os
# instances Vercel compartilham o mesmo contador de requests por IP).
# Se ausente, o fallback in-memory é usado automaticamente.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# WhatsApp Cloud API — HMAC-SHA256 webhook verification (AH-001)
# Obtenha em: Meta Developer Console → seu App → WhatsApp → Configuration → App Secret
# CRÍTICO: sem este valor, todos os POST /api/webhooks/whatsapp retornam 403 (fail-closed)
WHATSAPP_APP_SECRET=
