{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci --legacy-peer-deps",
  "framework": "vite",

  "rewrites": [
    {
      "source": "/api/observations/versions/:path*",
      "destination": "/api/observations/versions/index"
    },
    {
      "source": "/api/observations/([^/]+)/versions",
      "destination": "/api/observations/[id]/versions"
    },
    {
      "source": "/api/observations/:id",
      "destination": "/api/observations/[id]"
    },
    {
      "source": "/api/observations",
      "destination": "/api/observations/index"
    },
    {
      "source": "/api/cycles/:id",
      "destination": "/api/cycles/[id]"
    },
    {
      "source": "/api/cycles",
      "destination": "/api/cycles/index"
    },
    {
      "source": "/api/instructor-student-links/pending",
      "destination": "/api/instructor-student-links/pending"
    },
    {
      "source": "/api/instructor-student-links/:id",
      "destination": "/api/instructor-student-links/[id]"
    },
    {
      "source": "/api/instructor-student-links",
      "destination": "/api/instructor-student-links/index"
    },
    {
      "source": "/api/users/me",
      "destination": "/api/users/me"
    },
    {
      "source": "/api/users/push-preferences",
      "destination": "/api/users/push-preferences/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.anthropic.com https://graph.facebook.com; worker-src 'self' blob:; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
